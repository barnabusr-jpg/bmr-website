# 🏛️ DATABASE CONFIGURATION
# Get this from your MongoDB Atlas "Drivers" connection string
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/database_name

# 🛡️ ADMIN ACCESS (For lab.bmradvisory.co/owner)
# Use secure, unique credentials for the forensic gate
ADMIN_USER=
ADMIN_PASS=

# 📡 COMMUNICATIONS (SendGrid)
# Required for automated PDF Verdict delivery
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
ADMIN_EMAIL=

# 🏛️ ENVIRONMENT SETTINGS
NODE_ENV=development
